<% content_for(:title, "Runs") %>

<%= render "shared/page_header",
      eyebrow: "Extraction",
      title: "Runs",
      subtitle: "Most recent #{[@runs.size, 100].min} extraction runs. Pick one to mark it active for the rest of the app." do %>
  <% if policy(ExtractionRun).create? %>
    <%= link_to "New run", new_run_path, class: "btn-primary" %>
  <% end %>
<% end %>

<%= form_with url: runs_path, method: :get, local: true, class: "card card-body mb-6 flex flex-wrap items-end gap-4 text-sm" do %>
  <div>
    <%= label_tag :status, "Status", class: "label" %>
    <%= select_tag :status,
          options_for_select([["All", ""], *ExtractionRun::STATUSES.map { |s| [s.tr("_", " "), s] }], params[:status]),
          class: "input" %>
  </div>
  <div>
    <%= label_tag :include_sensitive, "Sensitive", class: "label" %>
    <%= select_tag :include_sensitive,
          options_for_select([["All", ""], ["Yes", "1"], ["No", "0"]], params[:include_sensitive]),
          class: "input" %>
  </div>
  <%= submit_tag "Filter", class: "btn-secondary btn-sm" %>
<% end %>

<% if @runs.empty? %>
  <div class="empty-state">
    <h2>No runs yet</h2>
    <p>Extraction runs you trigger from Salesforce will show up here.</p>
    <% if policy(ExtractionRun).create? %>
      <div class="mt-4"><%= link_to "Run your first extraction", new_run_path, class: "btn-primary" %></div>
    <% end %>
  </div>
<% else %>
  <div class="card overflow-hidden">
    <table class="table-clean">
      <thead>
        <tr>
          <th>Run</th>
          <th>Status</th>
          <th>Started</th>
          <th>Completed</th>
          <th class="text-right">Objects</th>
          <th></th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @runs.each do |run| %>
          <% can_view = policy(run).show? %>
          <tr class="<%= 'bg-amber-50/40' if run.include_sensitive %>">
            <td>
              <div class="flex items-center gap-2">
                <% if can_view %>
                  <%= link_to run.directory_token, run_path(run), class: "font-mono text-sm font-medium text-blue-600 hover:text-blue-700" %>
                <% else %>
                  <span class="font-mono text-sm text-slate-400" title="Contains sensitive data — requires sensitive_data_access role."><%= run.directory_token %></span>
                <% end %>
                <% if run.include_sensitive %><span class="badge-warning">sensitive</span><% end %>
              </div>
            </td>
            <td><%= status_badge(run.status) %></td>
            <td class="text-slate-600 text-xs"><%= time_ago_or_dash(run.started_at) %></td>
            <td class="text-slate-600 text-xs"><%= time_ago_or_dash(run.completed_at) %></td>
            <td class="text-right tabular-nums text-slate-700"><%= can_view ? (@sobject_counts[run.id] || 0) : "—" %></td>
            <td></td>
            <td class="text-right">
              <% if can_view %>
                <%= button_to "Make active", select_run_path(run), method: :post, class: "btn-ghost btn-sm" %>
              <% else %>
                <span class="text-xs text-slate-400" title="Permission required">restricted</span>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
