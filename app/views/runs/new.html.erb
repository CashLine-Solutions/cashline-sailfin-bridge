<% content_for(:title, "New run") %>

<%= render "shared/page_header",
      eyebrow: "Extraction",
      title: "Trigger a new extraction",
      subtitle: "Starts a Salesforce describe walk from your seed objects, loads the schema into the local DB, then profiles each visited object (record count, null rate per field, distinct counts, top values).",
      breadcrumb_html: link_to("Runs", runs_path).html_safe + " / New".html_safe %>

<div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8 max-w-5xl">
  <%= form_with model: @run, url: runs_path, local: true, class: "card card-body space-y-6" do |f| %>
    <% if @run.errors.any? %>
      <div class="flash-alert">
        <strong class="font-semibold">Couldn't queue the run:</strong>
        <%= @run.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div>
      <%= f.label :preset, "Seed-object preset", class: "label" %>
      <%= f.select :preset,
                   options_for_select([
                     ["AR default — Account, Contact, Opportunity (standard only)", "ar_default"],
                     ["AR full — AR default + Task, Event, User, RecordType", "ar_full"],
                     ["Sailfin scope — AR + cashline custom + sfsrm/sfcapp", "sailfin_scope"]
                   ], "ar_default"),
                   {}, class: "input" %>
      <p class="help-text">Or supply a custom seed list below. The Sailfin scope preset also widens the walk's namespace allowlist to include managed-package objects (max_hops 4).</p>
    </div>

    <div>
      <%= f.label :seed_objects, "Custom seed objects", class: "label" %>
      <%= text_field_tag "extraction_run[seed_objects][]", "", class: "input", placeholder: "Invoice__c, Brand__c" %>
      <p class="help-text">Comma-separated. Leave empty to use the preset. Case-sensitive — use exact Salesforce API names with <code class="code-inline">__c</code> for custom objects.</p>
    </div>

    <div>
      <%= f.label :api_version, class: "label" %>
      <%= f.text_field :api_version, class: "input" %>
      <p class="help-text">Leave at the default unless you need a specific Salesforce API version. Bumping it across runs makes diffs noisy.</p>
    </div>

    <% if policy(ExtractionRun).trigger_with_pii? %>
      <div class="rounded-md bg-amber-50 ring-1 ring-amber-200 p-4">
        <label class="flex items-start gap-3">
          <%= f.check_box :include_sensitive, class: "mt-0.5 rounded border-amber-300 text-amber-600 focus:ring-amber-500" %>
          <span>
            <span class="block text-sm font-medium text-amber-900">Include sensitive (PII / financial) values</span>
            <span class="block text-xs text-amber-800 mt-0.5 leading-relaxed">Run is flagged sensitive, stored under <code class="code-inline">storage/runs/sensitive/</code> with mode 0700, and auto-purged after 30 days. An audit event is written either way.</span>
          </span>
        </label>
      </div>
    <% end %>

    <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
      <%= f.submit "Queue extraction", class: "btn-primary" %>
      <%= link_to "Cancel", runs_path, class: "btn-ghost" %>
    </div>
  <% end %>

  <aside class="space-y-4">
    <div class="card card-body text-sm text-slate-700">
      <h2 class="section-title text-base mb-2">What is a seed object?</h2>
      <p class="leading-relaxed">It's where the extraction <em>starts</em>. The walker doesn't just describe the seed — it follows every lookup and master-detail reference outward to discover related objects, then walks <em>their</em> references, until the preset's hop limit.</p>
      <p class="mt-3 leading-relaxed">Example: seed <code class="code-inline">Account</code> and the walker pulls in Contact, Opportunity, User, RecordType, and so on automatically — typically 15–30 standard objects from a single seed.</p>
    </div>
    <div class="card card-body text-sm text-slate-700">
      <h2 class="section-title text-base mb-2">Typical timing</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between gap-3">
          <dt class="text-slate-500">AR default (~20 objects)</dt>
          <dd class="font-medium text-slate-900 tabular-nums">1–3 min</dd>
        </div>
        <div class="flex justify-between gap-3">
          <dt class="text-slate-500">Sailfin scope (~100 objects)</dt>
          <dd class="font-medium text-slate-900 tabular-nums">10–30 min</dd>
        </div>
      </dl>
      <p class="help-text mt-3">Quota usage is in <code class="code-inline">bin/rails sailfin:limits</code>.</p>
    </div>
  </aside>
</div>
