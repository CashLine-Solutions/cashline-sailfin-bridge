<%# Fields table for a single sobject. Reused by:
    - objects/show.html.erb (the standalone page)
    - objects/fields.html.erb (the inline Turbo Frame inside objects/index)

    Locals:
      sobject         — Sobject
      sfields         — preloaded Sfield collection (ordered)
      field_profiles  — { sfield_id => FieldProfile }
      run             — ExtractionRun
      object_profile  — ObjectProfile (or nil)
      hide_value_cols — bool, hide Top/Samples for sensitive runs lacking access
      can_see_sensitive — bool, may view sensitive values
      compact         — bool, render in inline-expand mode (omits some chrome) %>

<% compact = local_assigns.fetch(:compact, false) %>
<%# Skip fields with a nil data_type from the chip row — they'd render as an
    unlabelled blank chip. Rare in practice (the column is nullable) but
    the chip UI doesn't have meaningful labelling for them. %>
<% type_counts = sfields.reject { |f| f.data_type.blank? }
                        .group_by(&:data_type)
                        .transform_values(&:size)
                        .sort_by { |_t, c| -c } %>

<div data-controller="type-filter"
     data-type-filter-active-class-value="chip-active"
     data-type-filter-inactive-class-value="chip">
  <% if type_counts.size > 1 %>
    <div class="mb-4 flex items-center gap-1.5 flex-wrap">
      <span class="eyebrow mr-1">Type</span>
      <button type="button"
              data-type-filter-target="chip"
              data-action="click->type-filter#filter"
              data-type-value="all"
              class="chip-active">All · <%= sfields.size %></button>
      <% type_counts.each do |t, c| %>
        <button type="button"
                data-type-filter-target="chip"
                data-action="click->type-filter#filter"
                data-type-value="<%= t %>"
                class="chip"><%= t %> · <%= c %></button>
      <% end %>
    </div>
  <% end %>

  <div class="overflow-x-auto -mx-5 sm:mx-0">
  <table class="table-clean" data-controller="sortable-table">
    <thead>
      <tr>
        <th class="cursor-pointer select-none hover:text-slate-700" data-action="click->sortable-table#sort" data-sort-type="text">API name<span class="sort-indicator"></span></th>
        <th class="cursor-pointer select-none hover:text-slate-700" data-action="click->sortable-table#sort" data-sort-type="text">Type<span class="sort-indicator"></span></th>
        <th class="cursor-pointer select-none hover:text-slate-700 text-right" data-action="click->sortable-table#sort" data-sort-type="number">Length<span class="sort-indicator"></span></th>
        <th class="cursor-pointer select-none hover:text-slate-700" data-action="click->sortable-table#sort" data-sort-type="text">Sensitivity<span class="sort-indicator"></span></th>
        <th class="cursor-pointer select-none hover:text-slate-700 text-right" data-action="click->sortable-table#sort" data-sort-type="number">Null %<span class="sort-indicator"></span></th>
        <th class="cursor-pointer select-none hover:text-slate-700 text-right" data-action="click->sortable-table#sort" data-sort-type="number">Distinct<span class="sort-indicator"></span></th>
        <% unless hide_value_cols %>
          <th>Top values</th>
          <th>Samples</th>
        <% end %>
        <th class="cursor-pointer select-none hover:text-slate-700 text-right" data-action="click->sortable-table#sort" data-sort-type="number">Refs<span class="sort-indicator"></span></th>
      </tr>
    </thead>
    <tbody data-sortable-table-target="body">
      <% sfields.each do |f| %>
        <% fp = field_profiles[f.id] %>
        <% may_view_values = f.sensitivity.to_s == "safe" || can_see_sensitive %>
        <% field_frame_id = dom_id(f, :detail) %>
        <% col_count = hide_value_cols ? 7 : 9 %>
        <tr data-field-name="<%= f.api_name %>"
            data-field-type="<%= f.data_type %>"
            data-controller="expandable"
            data-expandable-frame-id-value="<%= field_frame_id %>"
            data-expandable-frame-url-value="<%= field_object_path(sobject.api_name, field_name: f.api_name, run: run.id) %>">
          <td class="font-mono text-xs" data-sort-value="<%= f.api_name %>">
            <div class="flex items-center gap-1.5">
              <button type="button"
                      data-action="click->expandable#toggle"
                      class="inline-flex w-4 h-4 items-center justify-center rounded text-slate-400 hover:bg-slate-100 hover:text-slate-700"
                      aria-label="Expand field detail"
                      title="Show extended view">
                <span data-expandable-target="chevron" class="text-[9px]">▸</span>
              </button>
              <span class="text-slate-900"><%= f.api_name %></span>
              <% if f.calculated %><span class="badge-info">calc</span><% end %>
              <% if f.encrypted %><span class="badge-danger">enc</span><% end %>
              <% if %w[picklist multipicklist].include?(f.data_type) && f.picklist_count.to_i > 0 %>
                <span class="badge-neutral" title="<%= f.picklist_count %> picklist values"><%= f.picklist_count %> vals</span>
              <% end %>
            </div>
          </td>
          <td class="text-slate-600 text-xs"><%= f.data_type %></td>
          <td class="text-right tabular-nums text-slate-600 text-xs" data-sort-value="<%= f.length %>"><%= f.length || "—" %></td>
          <td data-sort-value="<%= f.sensitivity %>">
            <% if f.sensitivity == "safe" %>
              <span class="text-slate-400 text-xs"><%= sensitivity_label(f.sensitivity) %></span>
            <% else %>
              <span class="badge-warning"><%= sensitivity_label(f.sensitivity) %></span>
            <% end %>
          </td>
          <td class="text-right tabular-nums text-slate-700 text-xs" data-sort-value="<%= fp&.null_rate %>"><%= fp&.null_rate ? "#{(fp.null_rate * 100).round(1)}%" : "—" %></td>
          <td class="text-right tabular-nums text-slate-700 text-xs" data-sort-value="<%= fp&.distinct_count_suppressed ? nil : fp&.distinct_count %>">
            <% if fp.nil? %>—
            <% elsif fp.distinct_count_suppressed %><span class="italic text-slate-400" title="Distinct < 5 on sensitive field — suppressed">suppressed</span>
            <% else %><%= fp.distinct_count || "—" %><% end %>
          </td>
          <% unless hide_value_cols %>
            <td>
              <% if fp.nil? || fp.top_values.blank? %><span class="text-slate-300">—</span>
              <% elsif may_view_values %>
                <ul class="text-xs text-slate-600 space-y-0.5"><% fp.top_values.first(5).each do |tv| %><li><%= tv["value"] || tv["v"] %> <span class="text-slate-400">(<%= tv["count"] || tv["c"] %>)</span></li><% end %></ul>
              <% else %>
                <%= redacted_cell(f) %>
              <% end %>
            </td>
            <td>
              <% if fp.nil? || fp.sample_values.blank? %><span class="text-slate-300">—</span>
              <% elsif may_view_values %>
                <ul class="text-xs text-slate-600 space-y-0.5"><% fp.sample_values.first(3).each do |s| %><li><%= s.to_s.truncate(40) %></li><% end %></ul>
              <% else %>
                <%= redacted_cell(f) %>
              <% end %>
            </td>
          <% end %>
          <td class="text-right tabular-nums text-slate-700 text-xs"><%= f.references_count %></td>
        </tr>
        <%# Use the HTML `hidden` attribute (not just .hidden class) so the
            row is enforced display:none by Tailwind's Preflight !important
            rule — defends against any future specificity collision with the
            .table-clean row styling. expandable_controller toggles the
            attribute. %>
        <tr id="<%= field_frame_id %>-row" hidden data-detail-for="<%= f.api_name %>" data-field-type="<%= f.data_type %>">
          <td colspan="<%= col_count %>" class="p-0 border-0">
            <%= turbo_frame_tag field_frame_id do %>
              <div class="bg-slate-50/70 px-5 py-3 text-xs text-slate-500">Loading field detail…</div>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>
