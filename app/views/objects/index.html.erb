<% content_for(:title, "Objects") %>

<%= render "shared/page_header",
      eyebrow: "Schema",
      title: "Objects",
      subtitle: (@run ? "Salesforce objects discovered by the extraction walk. Filter and download as CSV for offline mapping work." : nil) do %>
  <% if @run %>
    <%= link_to objects_path(request.query_parameters.merge(format: :csv)),
          class: "btn-secondary btn-sm",
          title: "Download the filtered field list as CSV (one row per field, sensitive values redacted)" do %>
      <svg class="w-3.5 h-3.5" viewBox="0 0 20 20" fill="currentColor"><path d="M10 2a1 1 0 011 1v9.586l3.293-3.293a1 1 0 111.414 1.414l-5 5a1 1 0 01-1.414 0l-5-5a1 1 0 111.414-1.414L9 12.586V3a1 1 0 011-1z"/><path d="M3 17a1 1 0 011-1h12a1 1 0 110 2H4a1 1 0 01-1-1z"/></svg>
      Download CSV
    <% end %>
  <% end %>
<% end %>

<% if @run.nil? %>
  <div class="empty-state">
    <h2>No active run</h2>
    <p>Select a run to browse its objects.</p>
    <div class="mt-4"><%= link_to "Pick a run", runs_path, class: "btn-primary" %></div>
  </div>
<% else %>
  <%# Filter state lives in URL params so any view is shareable. Building a
      base param hash makes "preserve other filters" easy on each chip. %>
  <% base_params = { run: @run.id, q: params[:q], namespace: params[:namespace],
                     custom: params[:custom], sensitivity: params[:sensitivity],
                     min_fields: params[:min_fields] }.compact_blank %>

  <div class="card card-body mb-6 space-y-4">
    <%= form_with url: objects_path, method: :get, local: true, class: "flex flex-wrap items-center gap-2" do %>
      <%= hidden_field_tag :run, @run.id %>
      <% %i[namespace custom sensitivity min_fields].each do |key| %>
        <%= hidden_field_tag key, params[key] if params[key].present? %>
      <% end %>
      <div class="relative flex-1 max-w-sm">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"/></svg>
        <%= text_field_tag :q, params[:q], placeholder: "Search API name…", class: "input pl-9" %>
      </div>
      <%= submit_tag "Search", class: "btn-secondary btn-sm" %>
      <% if params[:q].present? %>
        <%= link_to "Clear", objects_path(base_params.except(:q)), class: "btn-ghost btn-sm" %>
      <% end %>
    <% end %>

    <div class="flex items-start flex-wrap gap-3 pt-3 border-t border-slate-100">
      <span class="eyebrow pt-1.5">Namespace</span>
      <div class="flex flex-wrap gap-1.5">
        <%= link_to "All", objects_path(base_params.except(:namespace)), class: (params[:namespace].blank? ? "chip-active" : "chip") %>
        <% @namespace_facets.sort_by { |_ns, count| -count }.each do |ns, count| %>
          <% active = params[:namespace].to_s == ns.to_s || (ns == "standard" && params[:namespace] == "standard") %>
          <%= link_to "#{ns} (#{count})", objects_path(base_params.merge(namespace: ns)), class: (active ? "chip-active" : "chip") %>
        <% end %>
      </div>
    </div>

    <div class="flex items-start flex-wrap gap-3 pt-3 border-t border-slate-100">
      <span class="eyebrow pt-1.5">Filters</span>
      <div class="flex flex-wrap gap-1.5">
        <%= link_to "Custom only",
                    objects_path(params[:custom] == "1" ? base_params.except(:custom) : base_params.merge(custom: "1")),
                    class: (params[:custom] == "1" ? "chip-active" : "chip") %>
        <%= link_to "Has PII",
                    objects_path(params[:sensitivity] == "pii" ? base_params.except(:sensitivity) : base_params.merge(sensitivity: "pii")),
                    class: (params[:sensitivity] == "pii" ? "chip-active" : "chip") %>
        <%= link_to "Has Financial",
                    objects_path(params[:sensitivity] == "financial" ? base_params.except(:sensitivity) : base_params.merge(sensitivity: "financial")),
                    class: (params[:sensitivity] == "financial" ? "chip-active" : "chip") %>
        <%= link_to "Any sensitive",
                    objects_path(params[:sensitivity] == "any" ? base_params.except(:sensitivity) : base_params.merge(sensitivity: "any")),
                    class: (params[:sensitivity] == "any" ? "chip-active" : "chip") %>
      </div>
      <span class="eyebrow pt-1.5 ml-2">Min fields</span>
      <div class="flex flex-wrap gap-1.5">
        <% [10, 50, 100].each do |n| %>
          <%= link_to "≥ #{n}",
                      objects_path(params[:min_fields].to_i == n ? base_params.except(:min_fields) : base_params.merge(min_fields: n)),
                      class: (params[:min_fields].to_i == n ? "chip-active" : "chip") %>
        <% end %>
      </div>
      <% if base_params.except(:run, :q).any? %>
        <%= link_to "× Clear filters",
                    objects_path(run: @run.id, q: params[:q]),
                    class: "text-xs font-medium text-rose-600 hover:text-rose-700 ml-auto self-center" %>
      <% end %>
    </div>

    <p class="text-xs text-slate-500 pt-1"><span class="font-medium text-slate-700"><%= @sobjects.size %></span> <%= "object".pluralize(@sobjects.size) %> shown</p>
  </div>

  <div class="card overflow-hidden">
    <table class="table-clean" data-controller="sortable-table">
      <thead>
        <tr>
          <th class="cursor-pointer select-none hover:text-slate-700" data-action="click->sortable-table#sort" data-sort-type="text">API name<span class="sort-indicator"></span></th>
          <th class="cursor-pointer select-none hover:text-slate-700" data-action="click->sortable-table#sort" data-sort-type="text">Label<span class="sort-indicator"></span></th>
          <th class="cursor-pointer select-none hover:text-slate-700" data-action="click->sortable-table#sort" data-sort-type="text">Namespace<span class="sort-indicator"></span></th>
          <th class="cursor-pointer select-none hover:text-slate-700 text-right" data-action="click->sortable-table#sort" data-sort-type="number">Fields<span class="sort-indicator"></span></th>
          <th class="cursor-pointer select-none hover:text-slate-700" data-action="click->sortable-table#sort" data-sort-type="text">Type<span class="sort-indicator"></span></th>
        </tr>
      </thead>
      <tbody data-sortable-table-target="body">
        <% @sobjects.each do |so| %>
          <% frame_id = dom_id(so, :fields) %>
          <tr data-field-name="<%= so.api_name %>"
              data-controller="expandable"
              data-expandable-frame-id-value="<%= frame_id %>"
              data-expandable-frame-url-value="<%= fields_object_path(so.api_name, run: @run.id) %>">
            <td data-sort-value="<%= so.api_name %>">
              <div class="flex items-center gap-2">
                <button type="button"
                        data-action="click->expandable#toggle"
                        class="inline-flex w-5 h-5 items-center justify-center rounded text-slate-400 hover:bg-slate-100 hover:text-slate-700 transition-colors"
                        aria-label="Expand fields"
                        title="Show fields inline">
                  <span data-expandable-target="chevron" class="text-[10px]">▸</span>
                </button>
                <%= link_to so.api_name, object_path(so.api_name, run: @run.id), class: "font-mono text-sm font-medium text-blue-600 hover:text-blue-700" %>
              </div>
            </td>
            <td class="text-slate-700"><%= so.label %></td>
            <td><span class="badge-neutral"><%= so.namespace_prefix.presence || "standard" %></span></td>
            <td class="text-right tabular-nums font-medium text-slate-900" data-sort-value="<%= @sfield_counts[so.id] || 0 %>"><%= @sfield_counts[so.id] || 0 %></td>
            <td>
              <% if so.custom %>
                <span class="badge-info">custom</span>
              <% else %>
                <span class="text-xs text-slate-500">standard</span>
              <% end %>
            </td>
          </tr>
          <tr id="<%= frame_id %>-row" hidden data-detail-for="<%= so.api_name %>">
            <td colspan="5" class="p-0 border-0">
              <%# Frame starts without src — expandable_controller sets src on first toggle %>
              <%= turbo_frame_tag frame_id do %>
                <div class="bg-slate-50/70 px-5 py-3 text-xs text-slate-500">Loading fields…</div>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
