<% content_for(:title, "Sailfin field fate") %>
<% content_for(:full_width, true) %>

<%= render "shared/page_header",
      eyebrow: "Resolution",
      title: "Sailfin field fate",
      subtitle: "One row per Sailfin field. What's happening to it — disposition, shape, target set." do %>
  <%= render "view_switcher", current: :source %>
<% end %>

<% chip_on = "rounded bg-slate-900 text-white px-3 py-1 text-xs font-medium" %>
<% chip_off = "rounded border border-slate-300 bg-white text-slate-700 hover:border-slate-500 px-3 py-1 text-xs" %>
<% base = { sobject: params[:sobject], attention: params[:attention] }.compact_blank %>
<% toggle = ->(key, val) { params[key].to_s == val.to_s ? base.except(key) : base.merge(key => val) } %>

<div class="mb-4 space-y-2">
  <div class="flex flex-wrap items-center gap-2 text-xs">
    <span class="text-slate-500 font-medium">Disposition:</span>
    <% [ %w[keep Keep], %w[need_in_cashline Need], %w[sync_reference Sailfin\ sync], %w[discard Discard], %w[unreviewed Unreviewed] ].each do |val, label| %>
      <% next if @disposition_counts[val].to_i.zero? %>
      <%= link_to "#{label} #{@disposition_counts[val]}", resolutions_by_source_path(toggle.call(:disposition, val)),
            class: (params[:disposition] == val ? chip_on : chip_off) %>
    <% end %>
    <% if params[:disposition].present? %>
      <%= link_to "× clear", resolutions_by_source_path(base.except(:disposition)),
            class: "text-rose-600 hover:text-rose-800 ml-1 underline text-xs" %>
    <% end %>
  </div>

  <div class="flex flex-wrap items-center gap-2 text-xs">
    <span class="text-slate-500 font-medium">Worklist:</span>
    <%= link_to "Needs my attention", resolutions_by_source_path(toggle.call(:attention, "1")),
          class: (params[:attention] == "1" ? chip_on : chip_off),
          title: "Unreviewed, high-population fields with a candidate target waiting" %>
    <span class="text-slate-500 ml-2 font-medium">Object:</span>
    <%= form_with url: resolutions_by_source_path, method: :get, local: true, class: "inline-flex items-center gap-2" do %>
      <% params.permit(:disposition, :attention).to_h.each { |k, v| %><%= hidden_field_tag k, v %><% } %>
      <%= select_tag :sobject,
            options_for_select([[ "All objects", "" ]] + @sobject_options.map { |c| [ c, c ] }, params[:sobject]),
            onchange: "this.form.submit()",
            class: "rounded border border-slate-300 text-xs py-0.5 px-2" %>
    <% end %>
  </div>
</div>

<div class="mb-2 flex items-center justify-between">
  <p class="text-xs text-slate-500">
    <% filtered = @rows.size != @total_count %>
    <% if filtered %>
      <span class="font-semibold text-slate-700"><%= number_with_delimiter(@rows.size) %></span>
      of <%= number_with_delimiter(@total_count) %> Sailfin fields (filtered)
    <% else %>
      <span class="font-semibold text-slate-700"><%= number_with_delimiter(@total_count) %></span> Sailfin fields
    <% end %>
  </p>
</div>

<div class="rounded-l border-y border-l border-slate-200 bg-white">
  <table class="min-w-full divide-y divide-slate-200 text-sm">
    <thead class="bg-slate-100 text-left text-xs uppercase tracking-wide text-slate-600">
      <tr>
        <th class="sticky top-0 z-10 bg-slate-100 px-2 py-1.5">Object</th>
        <th class="sticky top-0 z-10 bg-slate-100 px-2 py-1.5">Field</th>
        <th class="sticky top-0 z-10 bg-slate-100 px-2 py-1.5">Disposition</th>
        <th class="sticky top-0 z-10 bg-slate-100 px-2 py-1.5">Shape</th>
        <th class="sticky top-0 z-10 bg-slate-100 px-2 py-1.5">Resolves to</th>
        <th class="sticky top-0 z-10 bg-slate-100 px-2 py-1.5 text-right">Pop</th>
        <th class="sticky top-0 z-10 bg-slate-100 px-2 py-1.5 text-right">Conf</th>
        <th class="sticky top-0 z-10 bg-slate-100 px-2 py-1.5">Role note</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% if @rows.empty? %>
        <tr><td colspan="8" class="px-3 py-6 text-center text-slate-500">Nothing matches these filters.</td></tr>
      <% else %>
        <% @rows.each do |row| %>
          <% # Jump to the existing /mappings grid anchored at this Sailfin field — the
             # mapping row dom_id depends on whether a MappingEntry already exists.
             anchor = row.entries.any? ? "mapping_entry_#{row.entries.first.id}" : "mapping_synthetic_#{row.sfield.id}"
             edit_url = url_for(controller: "mappings", action: "index", snapshot: @snapshot&.id, anchor: anchor) %>
          <tr id="<%= row.dom_id %>" class="hover:bg-slate-50 align-top">
            <td class="px-2 py-1.5 font-mono text-xs text-slate-700 whitespace-nowrap"><%= link_to row.sobject_name, edit_url, class: "hover:underline" %></td>
            <td class="px-2 py-1.5 font-mono text-xs text-slate-900 whitespace-nowrap"><%= link_to row.field_name, edit_url, class: "hover:underline" %></td>
            <td class="px-2 py-1.5 whitespace-nowrap">
              <span class="inline-block rounded bg-<%= row.disposition_color %>-100 text-<%= row.disposition_color %>-800 px-2 py-0.5 text-xs font-medium">
                <%= row.disposition_label %>
              </span>
            </td>
            <td class="px-2 py-1.5 whitespace-nowrap">
              <span class="inline-block rounded bg-<%= row.shape_color %>-100 text-<%= row.shape_color %>-800 px-1.5 py-0.5 text-xs font-medium">
                <%= row.shape %>
              </span>
            </td>
            <td class="px-2 py-1.5" style="max-width: 22rem;">
              <% if row.target_chips.any? %>
                <div class="flex flex-wrap gap-1">
                  <% row.target_chips.each do |chip| %>
                    <span class="inline-block rounded bg-slate-100 text-slate-700 px-1.5 py-0.5 text-xs font-mono"><%= chip %></span>
                  <% end %>
                </div>
                <% if row.resolved_targets.empty? && row.suggested_targets.any? %>
                  <span class="text-xs text-slate-400 italic">suggestion</span>
                <% end %>
              <% else %>
                <span class="text-xs text-slate-400 italic">—</span>
              <% end %>
            </td>
            <td class="px-2 py-1.5 text-right text-xs text-slate-700 whitespace-nowrap">
              <%= row.population ? "#{(row.population * 100).round}%" : "—" %>
            </td>
            <td class="px-2 py-1.5 text-right text-xs text-slate-500 whitespace-nowrap">
              <%= row.confidence ? "#{(row.confidence * 100).round}%" : "—" %>
              <% if row.model %><span class="text-slate-400 ml-0.5"><%= row.model %></span><% end %>
            </td>
            <td class="px-2 py-1.5 text-xs text-slate-600" style="max-width: 28rem;">
              <%= row.role_note || row.label || "—" %>
            </td>
          </tr>
        <% end %>
      <% end %>
    </tbody>
  </table>
</div>
