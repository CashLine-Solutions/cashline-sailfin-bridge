<%# Toggle between by_source and by_target. Locals: current (:source or :target). %>
<div class="inline-flex rounded border border-slate-300 bg-white p-0.5 text-xs">
  <%= link_to "By cashline field", resolutions_by_target_path,
        class: "rounded px-3 py-1 #{current == :target ? "bg-slate-900 text-white" : "text-slate-600 hover:bg-slate-100"}" %>
  <%= link_to "By Sailfin field", resolutions_by_source_path,
        class: "rounded px-3 py-1 #{current == :source ? "bg-slate-900 text-white" : "text-slate-600 hover:bg-slate-100"}" %>
</div>
