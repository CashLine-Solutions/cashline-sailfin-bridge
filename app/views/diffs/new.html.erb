<% content_for(:title, "New diff") %>
<nav class="text-sm text-slate-600 mb-3"><%= link_to "Runs", runs_path, class: "underline" %> / New diff</nav>
<h1 class="text-2xl font-semibold mb-4">Compare two extraction runs</h1>

<%= form_with url: diffs_path, method: :post, local: true, class: "rounded border border-slate-200 bg-white p-6 max-w-2xl space-y-5" do %>
  <% if flash.now[:alert].present? %>
    <div class="rounded bg-rose-50 text-rose-900 px-3 py-2 text-sm"><%= flash.now[:alert] %></div>
  <% end %>

  <% if @runs.empty? %>
    <p class="text-slate-700 text-sm">No runs available. <%= link_to "Trigger one", new_run_path, class: "text-blue-700 underline" if policy(ExtractionRun).create? %>.</p>
  <% else %>
    <div>
      <%= label_tag :run_a_id, "From run (baseline)", class: "block text-sm font-medium text-slate-700" %>
      <%= select_tag :run_a_id,
                     options_from_collection_for_select(@runs, :id, :directory_token, @run_a&.id),
                     include_blank: true, class: "mt-1 block w-full rounded border-slate-300" %>
    </div>

    <div>
      <%= label_tag :run_b_id, "To run (compared)", class: "block text-sm font-medium text-slate-700" %>
      <%= select_tag :run_b_id,
                     options_from_collection_for_select(@runs, :id, :directory_token, @run_b&.id),
                     include_blank: true, class: "mt-1 block w-full rounded border-slate-300" %>
    </div>

    <p class="text-xs text-slate-500">Categories: object/field add/remove, type/length/picklist/formula changes, relationship add/remove, and installed-package changes.</p>

    <div class="flex items-center gap-3">
      <%= submit_tag "Compute diff", class: "rounded bg-slate-900 text-white px-4 py-2 text-sm" %>
      <%= link_to "Cancel", runs_path, class: "text-sm text-slate-600 underline" %>
    </div>
  <% end %>
<% end %>
