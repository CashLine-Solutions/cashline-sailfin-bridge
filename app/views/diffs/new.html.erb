<% content_for(:title, "New diff") %>

<%= render "shared/page_header",
      eyebrow: "Compare",
      title: "Compare two extraction runs",
      subtitle: "Pick a baseline and a comparison run. The diff covers objects, fields (add/remove/type/length/picklist/formula), relationships, and installed packages.",
      breadcrumb_html: link_to("Runs", runs_path).html_safe + " / New diff".html_safe %>

<%= form_with url: diffs_path, method: :post, local: true, class: "card card-body max-w-xl space-y-6" do %>
  <% if flash.now[:alert].present? %>
    <div class="flash-alert"><%= flash.now[:alert] %></div>
  <% end %>

  <% if @runs.empty? %>
    <div class="empty-state">
      <h2>No runs available</h2>
      <p>Trigger an extraction to populate the diff picker.</p>
      <% if policy(ExtractionRun).create? %>
        <div class="mt-4"><%= link_to "Trigger one", new_run_path, class: "btn-primary" %></div>
      <% end %>
    </div>
  <% else %>
    <div>
      <%= label_tag :run_a_id, "From (baseline)", class: "label" %>
      <%= select_tag :run_a_id,
                     options_from_collection_for_select(@runs, :id, :directory_token, @run_a&.id),
                     include_blank: true, class: "input" %>
    </div>

    <div>
      <%= label_tag :run_b_id, "To (compared)", class: "label" %>
      <%= select_tag :run_b_id,
                     options_from_collection_for_select(@runs, :id, :directory_token, @run_b&.id),
                     include_blank: true, class: "input" %>
    </div>

    <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
      <%= submit_tag "Compute diff", class: "btn-primary" %>
      <%= link_to "Cancel", runs_path, class: "btn-ghost" %>
    </div>
  <% end %>
<% end %>
