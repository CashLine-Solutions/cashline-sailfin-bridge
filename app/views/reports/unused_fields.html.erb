<% content_for(:title, "Unused fields") %>

<%= render "shared/page_header",
      eyebrow: "Report",
      title: "Unused fields",
      subtitle: "Fields with null rate at or above the threshold. Candidates for trimming during ontology design." do %>
  <% if @run %><%= link_to "Download CSV", reports_unused_fields_path(run: @run.id, threshold: @threshold, format: :csv), class: "btn-secondary btn-sm" %><% end %>
<% end %>

<%= render "tabs", active: "unused_fields" %>

<% if @run.nil? %>
  <div class="empty-state">
    <h2>No active run</h2>
    <p>Select a run to compute the report.</p>
    <div class="mt-4"><%= link_to "Pick a run", runs_path, class: "btn-primary" %></div>
  </div>
<% else %>
  <%= form_with url: reports_unused_fields_path, method: :get, local: true, class: "card card-body mb-6 flex flex-wrap items-end gap-3" do %>
    <%= hidden_field_tag :run, @run.id %>
    <div>
      <%= label_tag :threshold, "Null-rate threshold", class: "label" %>
      <%= number_field_tag :threshold, @threshold, step: 0.01, min: 0, max: 1, class: "input w-32" %>
    </div>
    <%= submit_tag "Apply", class: "btn-secondary btn-sm" %>
    <p class="text-xs text-slate-500 ml-auto self-center">Currently showing fields with ≥ <span class="font-medium text-slate-700"><%= (@threshold.to_f * 100).round %>%</span> null rate.</p>
  <% end %>

  <% if @rows.empty? %>
    <div class="empty-state">
      <h2>Nothing to flag</h2>
      <p>No fields meet the current threshold.</p>
    </div>
  <% else %>
    <div class="card overflow-hidden">
      <table class="table-clean">
        <thead>
          <tr>
            <th>Object</th>
            <th>Field</th>
            <th>Type</th>
            <th>Sensitivity</th>
            <th class="text-right">Null %</th>
          </tr>
        </thead>
        <tbody>
          <% @rows.each do |r| %>
            <tr>
              <td><%= link_to r[:sobject], object_path(r[:sobject], run: @run.id), class: "font-mono text-sm font-medium text-blue-600 hover:text-blue-700" %></td>
              <td class="font-mono text-xs text-slate-700"><%= r[:field] %></td>
              <td><span class="badge-neutral"><%= r[:type] %></span></td>
              <td class="text-slate-600 text-sm"><%= sensitivity_label(r[:sensitivity]) %></td>
              <td class="text-right tabular-nums font-medium text-slate-900"><%= (r[:null_rate].to_f * 100).round(1) %>%</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
<% end %>
