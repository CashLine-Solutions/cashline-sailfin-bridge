<% content_for(:title, "Mapping order") %>

<%= render "shared/page_header",
      eyebrow: "Report",
      title: "Suggested mapping order",
      subtitle: "Walk the buckets top-to-bottom so dependents can point at already-mapped anchors. This is a heuristic — adjust as you learn the domain." do %>
  <% if @run %><%= link_to "Download CSV", reports_mapping_order_path(run: @run.id, format: :csv), class: "btn-secondary btn-sm" %><% end %>
<% end %>

<%= render "tabs", active: "mapping_order" %>

<% if @run.nil? %>
  <div class="empty-state">
    <h2>No active run</h2>
    <p>Select a run to compute the report.</p>
    <div class="mt-4"><%= link_to "Pick a run", runs_path, class: "btn-primary" %></div>
  </div>
<% else %>
  <%
    bucket_meta = {
      "anchor"   => { badge_class: "badge-success",  title: "Anchors — map these first", blurb: "Heavily referenced; their mappings become the range of object properties on everything else." },
      "entity"   => { badge_class: "badge-info",     title: "Entities — substantive objects", blurb: "The bulk of the domain. Ordered most-referenced first." },
      "junction" => { badge_class: "badge-warning",  title: "Junctions — link tables", blurb: "Map last; they're typically associations between already-mapped entities." }
    }
  %>
  <% @bucket_order.each do |bucket| %>
    <% meta = bucket_meta[bucket] %>
    <% rows = @bucketed[bucket] || [] %>
    <% next if rows.empty? %>
    <section class="card mb-6 overflow-hidden">
      <div class="card-header">
        <div class="flex items-center gap-2 mb-1">
          <span class="<%= meta[:badge_class] %>"><%= bucket %></span>
          <span class="text-xs text-slate-400 font-medium"><%= rows.size %> objects</span>
        </div>
        <h2 class="section-title"><%= meta[:title] %></h2>
        <p class="section-subtitle"><%= meta[:blurb] %></p>
      </div>
      <div class="overflow-x-auto">
        <table class="table-clean">
          <thead>
            <tr>
              <th class="text-right w-12">#</th>
              <th>Object</th>
              <th>Namespace</th>
              <th class="text-right">Fields</th>
              <th class="text-right">Inbound</th>
              <th class="text-right">Outbound</th>
              <th>Rationale</th>
            </tr>
          </thead>
          <tbody>
            <% rows.each_with_index do |r, idx| %>
              <tr>
                <td class="text-right tabular-nums text-xs text-slate-400"><%= idx + 1 %></td>
                <td><%= link_to r[:api_name], object_path(r[:api_name], run: @run.id), class: "font-mono text-sm font-medium text-blue-600 hover:text-blue-700" %></td>
                <td><span class="badge-neutral"><%= r[:namespace_prefix].presence || "standard" %></span></td>
                <td class="text-right tabular-nums text-slate-700"><%= r[:field_count] %></td>
                <td class="text-right tabular-nums text-slate-700"><%= r[:in_count] %></td>
                <td class="text-right tabular-nums text-slate-700"><%= r[:out_count] %></td>
                <td class="text-xs text-slate-500"><%= r[:rationale] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </section>
  <% end %>
<% end %>
