<% content_for(:title, "Hub / orphan report") %>

<%= render "shared/page_header",
      eyebrow: "Report",
      title: "Hub / orphan",
      subtitle: "Objects ranked by total relationship degree. Orphans listed separately." do %>
  <% if @run %><%= link_to "Download CSV", reports_hub_orphan_path(run: @run.id, format: :csv), class: "btn-secondary btn-sm" %><% end %>
<% end %>

<%= render "tabs", active: "hub_orphan" %>

<% if @run.nil? %>
  <div class="empty-state">
    <h2>No active run</h2>
    <p>Select a run to compute the report.</p>
    <div class="mt-4"><%= link_to "Pick a run", runs_path, class: "btn-primary" %></div>
  </div>
<% else %>
  <section class="card mb-6">
    <div class="card-header">
      <h2 class="section-title">Most connected (hubs)</h2>
      <p class="section-subtitle">Top 50 by inbound + outbound references.</p>
    </div>
    <div class="overflow-x-auto">
      <table class="table-clean">
        <thead>
          <tr>
            <th>Object</th>
            <th>Namespace</th>
            <th class="text-right">Outbound</th>
            <th class="text-right">Inbound</th>
            <th class="text-right">Total</th>
          </tr>
        </thead>
        <tbody>
          <% @nonorphans.first(50).each do |r| %>
            <tr>
              <td><%= link_to r[:api_name], object_path(r[:api_name], run: @run.id), class: "font-mono text-sm font-medium text-blue-600 hover:text-blue-700" %></td>
              <td><span class="badge-neutral"><%= r[:namespace_prefix].presence || "standard" %></span></td>
              <td class="text-right tabular-nums text-slate-700"><%= r[:out_count] %></td>
              <td class="text-right tabular-nums text-slate-700"><%= r[:in_count] %></td>
              <td class="text-right tabular-nums font-semibold text-slate-900"><%= r[:out_count].to_i + r[:in_count].to_i %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section class="card card-body">
    <h2 class="section-title">Orphans</h2>
    <p class="section-subtitle mb-4">No inbound or outbound references.</p>
    <% if @orphans.empty? %>
      <p class="text-sm text-slate-500">None — every object touches at least one other.</p>
    <% else %>
      <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-x-6 gap-y-1.5 text-sm">
        <% @orphans.each do |r| %>
          <li>
            <%= link_to r[:api_name], object_path(r[:api_name], run: @run.id), class: "font-mono text-sm text-blue-600 hover:text-blue-700" %>
            <span class="text-xs text-slate-400">· <%= r[:namespace_prefix].presence || "standard" %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </section>
<% end %>
